# Copy this file to .env and fill in your values.

# ── Google Gemini (all LLM calls + web search) ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Game ──────────────────────────────────────────────────────────────────────
MAX_CHAMBERS=20
